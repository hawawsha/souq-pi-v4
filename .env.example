# ============================================
# Souq Pi - Dynamic Network Configuration
# Set PI_NETWORK to 'testnet' or 'mainnet'
# ============================================

# Network Configuration (Dynamic)
PI_NETWORK=testnet
# PI_NETWORK=mainnet

# Application Credentials (Set based on network)
PI_APP_ID=your_app_id
PI_APP_SECRET=your_app_secret
PI_API_KEY=your_api_key

# Server Wallet
SERVER_WALLET_PUBLIC_KEY=G_...
SERVER_WALLET_SECRET_KEY=S_...

# Database
MONGODB_URI=mongodb+srv://...

# Security
JWT_SECRET=your_jwt_secret

ADMIN_SECRET=SouqPi_Admin_2026_Secret

# Refund Settings
REFUND_MAX_RETRIES=2
REFUND_RETRY_DELAY_MS=5000

# Logging
LOG_LEVEL=info
