# Souq Pi — TESTNET Environment Variables
# Add these in Vercel project settings (Environment Variables tab)

# Pi Network — TESTNET API Key (from developers.minepi.com → your testnet app)
PI_NETWORK_API_KEY=your_TESTNET_pi_api_key_here

# Airtable — Personal Access Token
AIRTABLE_TOKEN=your_airtable_token_here

# Airtable — Base ID (use Testnet Airtable base)
AIRTABLE_BASE_ID=your_airtable_base_id_here

# Admin Panel Secret Key
ADMIN_SECRET_KEY=your_admin_secret_here

# Mainnet wallet — leave empty for testnet
MAINNET_WALLET_ADDRESS=
